<mujoco model="ayg">
  <compiler angle="radian" meshdir="../meshes"/>

  <option timestep="0.001" iterations="50" solver="Newton" gravity="0 0 -9.81"
          noslip_iterations="5"/>

  <default>
    <joint damping="0" armature="0"/>
    <geom friction="1.5 0.005 0.001" condim="6" contype="1" conaffinity="1" solimp="0.9 0.95 0.001" solref="0.02 1"/>
    <motor ctrllimited="true"/>
  </default>

  <asset>
    <texture type="2d" name="grid" builtin="checker" rgb1="0.9 0.9 0.9" rgb2="0.6 0.6 0.6"
             width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8" reflectance="0.2"/>

    <mesh name="Base" file="Base.STL"/>
    <mesh name="L_Hip" file="L_Hip.STL"/>
    <mesh name="R_Hip" file="R_Hip.STL"/>
    <mesh name="L_Thigh" file="L_Thigh.STL"/>
    <mesh name="R_Thigh" file="R_Thigh.STL"/>
    <mesh name="L_Shank" file="L_Shank.STL"/>
