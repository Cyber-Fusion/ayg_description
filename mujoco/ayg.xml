    <mesh name="IMU" file="IMU.STL"/>
    <mesh name="Camera" file="Camera.STL"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>
    <geom name="floor" type="plane" size="5 5 0.1" material="grid_mat" contype="1" conaffinity="1"
          friction="1.5 0.005 0.001" condim="6" solimp="0.9 0.95 0.001" solref="0.02 1"/>

    <body name="Base" pos="0 0 0.18">
