  <actuator>
    <!-- Left Front -->
    <motor name="LF_HAA_motor" joint="LF_HAA" ctrlrange="-50 50" gear="1"/>
    <motor name="LF_HFE_motor" joint="LF_HFE" ctrlrange="-50 50" gear="1"/>
    <motor name="LF_KFE_motor" joint="LF_KFE" ctrlrange="-50 50" gear="1"/>
    <!-- Right Front -->
    <motor name="RF_HAA_motor" joint="RF_HAA" ctrlrange="-50 50" gear="1"/>
    <motor name="RF_HFE_motor" joint="RF_HFE" ctrlrange="-50 50" gear="1"/>
    <motor name="RF_KFE_motor" joint="RF_KFE" ctrlrange="-50 50" gear="1"/>
    <!-- Left Hind -->
    <motor name="LH_HAA_motor" joint="LH_HAA" ctrlrange="-50 50" gear="1"/>
    <motor name="LH_HFE_motor" joint="LH_HFE" ctrlrange="-50 50" gear="1"/>
    <motor name="LH_KFE_motor" joint="LH_KFE" ctrlrange="-50 50" gear="1"/>
    <!-- Right Hind -->
